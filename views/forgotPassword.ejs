<%- include('./partials/head.ejs') %>
<%- include('./partials/navigation.ejs') %>
<%- include('./partials/flash.ejs') %>
<main id="main-content">
  <section class="page-header">
    <article class="auth-card">
      <header>
        <h1 class="auth-card-title">Forgot Password</h1>
        <p class="auth-card-subtitle">Enter your email and we'll send you a reset link</p>
      </header>
      <form class="auth-form" action="/recover" method="POST">
        <div class="form-group">
          <label for="email">Email</label>
          <input id="email" type="email" name="email" placeholder="you@example.com" autocomplete="email" required aria-required="true">
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Send reset link</button>
        </div>
      </form>
      <footer>
        <p class="helper-text">Remember your password? <a href='/login'>Log in</a></p>
      </footer>
    </article>
  </section>
</main>
<%- include('./partials/footer.ejs') %>
